{
  "name": "poliglota-hambriento",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently \"node server.js\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server.js",
    "start": "node server.js",
    "mobile:install": "npm install --prefix mobile",
    "mobile:start": "npm run start --prefix mobile",
    "mobile:android": "npm run android --prefix mobile",
    "mobile:web": "npm run web --prefix mobile",
    "mobile:config": "cd mobile && npx expo config --type public",
    "mobile:apk": "cd mobile && npm run apk",
    "mobile:apk:prod": "cd mobile && npm run apk:prod",
    "mobile:eas:version": "cd mobile && npx eas --version"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "vite": "^5.1.0"
  }
}
